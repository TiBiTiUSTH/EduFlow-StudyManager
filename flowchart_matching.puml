@startuml
skinparam style strictuml
skinparam defaultFontName Arial
skinparam monochrome true
skinparam ActivityBackgroundColor white

start

:User clicks "Find Study Partner";
:Frontend sends API request to Backend;
:Backend fetches User's profile (Subjects, Grade, School);

:Backend queries PostgreSQL for all active users;
:Filter out inactive users and the requester;

while (More candidate users?) is (Yes)
  :Get next candidate profile;
  
  fork
    :Calculate Subject Score\n(Jaccard Similarity);
  fork again
    :Calculate Grade Score\n(Logical Step);
  fork again
    :Calculate School Score\n(Binary Match);
  end fork
  
  :Calculate Total Compatibility Score\n(Total = 50% Subj + 30% Grade + 20% School);
  :Assign Score to Candidate;
endwhile (No)

:Sort candidates by Total Score in descending order;
:Return top candidate matches to Frontend;
:Frontend displays candidate profiles to User;

stop
@enduml

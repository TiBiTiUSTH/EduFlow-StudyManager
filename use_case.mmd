graph TD
    %% Define Actors
    Student((Student))
    Admin((Admin))

    %% Define System Boundary
    subgraph EduFlow System
        UC1[Register & Login]
        UC2[Manage Study Tasks]
        UC3[Use AI Task Breaker]
        UC4[Join Study Room]
        UC5[Real-time Chat]
        UC6[View Admin Dashboard]
        UC7[System Cleanup]
    end

    %% Connections
    Student --> UC1
    Student --> UC2
    Student --> UC3
    Student --> UC4
    Student --> UC5

    Admin --> UC1
    Admin --> UC6
    Admin --> UC7

    classDef actor fill:#f9f,stroke:#333,stroke-width:2px;
    class Student,Admin actor;
